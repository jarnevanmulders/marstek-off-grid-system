[Unit]
Description=Mastek PV/Load controller Service
After=network.target

[Service]
ExecStart=/usr/bin/python3 /home/pi/marstek-off-grid-system/controller.py
WorkingDirectory=/home/pi/marstek-off-grid-system
Restart=always
RestartSec=30
User=pi
Environment=DISPLAY=:0

[Install]
WantedBy=multi-user.target